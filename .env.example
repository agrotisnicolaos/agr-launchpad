# agr-launchpad — local secrets. Copy this file to `.env` and fill in values.
# `.env` is gitignored and never committed. None of these are required to start —
# fill them in only for the features you want.

# GitHub MCP: a Personal Access Token so Claude can read/manage your repos, issues, PRs.
# Create one at https://github.com/settings/tokens (fine-grained, minimal scopes).
# Leave blank if you don't want the GitHub MCP yet.
GITHUB_PAT=

# Jupyter MCP (live notebooks): defaults work for local use; override only if needed.
# JUPYTER_URL=http://localhost:8888
# JUPYTER_TOKEN=agr-local-dev
