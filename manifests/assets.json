{
  "$schema_note": "agr-launchpad asset catalog. The base is deliberately lean and universal. Domain-specific assets live in packs/ and are merged in via `make use-pack`. This file is VALIDATED by `make check` (scripts/check.sh) against the real files — keep it in sync.",
  "repo": "agr-launchpad",
  "base": {
    "marketplaces": ["context-mode", "thedotmack", "agr-hub"],
    "plugins": {
      "declarative": [
        "superpowers@claude-plugins-official",
        "skill-creator@claude-plugins-official",
        "frontend-design@claude-plugins-official",
        "code-review@claude-plugins-official",
        "context-mode@context-mode",
        "claude-mem@thedotmack"
      ],
      "external_manual": [
        { "id": "gsd", "why": "installed globally into ~/.claude, not a repo plugin", "doc": "docs/onboarding.html" }
      ]
    },
    "mcpServers": [
      { "id": "context7", "purpose": "live library/framework docs" },
      { "id": "github", "purpose": "repos/issues/PRs (GitHub official hosted MCP)", "token": "${GITHUB_PAT} — must be exported in the shell that launches Claude Code" },
      { "id": "jupyter", "purpose": "live notebook kernel", "start": "make jupyter" },
      { "id": "chrome-devtools", "purpose": "optional: screenshots, console, network — visual verification of UI work" }
    ],
    "skills": [
      { "id": "grill-me", "path": ".claude/skills/grill-me/SKILL.md", "domain": "workflow" },
      { "id": "explain-agr", "path": ".claude/skills/explain-agr/SKILL.md", "domain": "learning", "origin": "first-party" },
      { "id": "coding-standards", "path": ".claude/skills/coding-standards/SKILL.md", "domain": "foundation", "origin": "ECC" },
      { "id": "error-handling", "path": ".claude/skills/error-handling/SKILL.md", "domain": "foundation", "origin": "ECC" },
      { "id": "secure-coding", "path": ".claude/skills/secure-coding/SKILL.md", "domain": "security", "origin": "ECC (upstream name: security-review)" },
      { "id": "api-design", "path": ".claude/skills/api-design/SKILL.md", "domain": "backend", "origin": "ECC" },
      { "id": "backend-patterns", "path": ".claude/skills/backend-patterns/SKILL.md", "domain": "backend", "origin": "ECC" },
      { "id": "frontend-patterns", "path": ".claude/skills/frontend-patterns/SKILL.md", "domain": "frontend", "origin": "ECC" },
      { "id": "webapp-testing", "path": ".claude/skills/webapp-testing/SKILL.md", "domain": "viz-verify", "origin": "anthropics/skills" },
      { "id": "html", "path": ".claude/skills/html/SKILL.md", "domain": "viz", "origin": "first-party" },
      { "id": "code-tour", "path": ".claude/skills/code-tour/SKILL.md", "domain": "foundation", "origin": "ECC" },
      { "id": "skill-stocktake", "path": ".claude/skills/skill-stocktake/SKILL.md", "domain": "meta", "origin": "ECC" }
    ],
    "agents": [
      { "id": "architect", "path": ".claude/agents/architect.md", "scope": "system-level design, ADRs" },
      { "id": "code-architect", "path": ".claude/agents/code-architect.md", "scope": "feature-level blueprints" },
      { "id": "code-explorer", "path": ".claude/agents/code-explorer.md", "scope": "existing-code tracing" }
    ],
    "tools": [
      { "id": "vscode-markitdown", "kind": "vscode-extension", "id_ext": "BioInfo.vscode-markitdown", "source": "https://github.com/BioInfo/vscode-markitdown" },
      { "id": "codetour", "kind": "vscode-extension", "id_ext": "vsls-contrib.codetour", "source": "https://github.com/microsoft/codetour", "why": "plays the .tour files produced by the code-tour skill" }
    ]
  },
  "packs": {
    "mechanism": "packs/<name> merged via scripts/use-pack.sh (make use-pack/new-pack/unuse-pack)",
    "populated": ["_template", "ops"],
    "planned": ["ml", "ios", "journal", "web", "backend"]
  }
}
